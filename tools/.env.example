# Copy to .env and fill in. Do NOT commit .env.
# Supabase project URL (https://<ref>.supabase.co)
SUPABASE_URL=
# Anonymous public key (safe for the browser)
SUPABASE_ANON_KEY=
# Service role key (server-only; never sent to a browser)
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection string (used by migration step only)
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
# Test users — created by handshakes, deleted by cleanup.ts
HANDSHAKE_USER_A_EMAIL=handshake-a@example.test
HANDSHAKE_USER_A_PASSWORD=Handshake!A1
HANDSHAKE_USER_B_EMAIL=handshake-b@example.test
HANDSHAKE_USER_B_PASSWORD=Handshake!B1
